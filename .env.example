# Copy to .env and set only what you use. Keep .env out of version control.

# --- 选用哪家 LLM（与本仓库 `streaming` 对接）---
# anthropic（默认，Messages API）| moonshot（Kimi，仅 OpenAI 兼容 /chat/completions）
# NOCODE_LLM=anthropic

# --- Kimi 与 Claude Code 相同（Anthropic Messages 兼容，保持 NOCODE_LLM=anthropic 默认即可）---
# 控制台申请 Key 后，与 Claude Code 一样使用「Anthropic 兼容」网关，不要用 …/v1 当 ANTHROPIC_BASE_URL。
# 程序会自动把 …/anthropic 规范为 …/anthropic/，否则 Python SDK 会误请求 …/anthropicv1/messages（404）。
# ANTHROPIC_BASE_URL=https://api.moonshot.ai/anthropic
# 国内账号常用（以控制台为准）：https://api.moonshot.cn/anthropic
# Claude Code 常用 ANTHROPIC_AUTH_TOKEN；本仓库与 ANTHROPIC_API_KEY 二选一即可。
# ANTHROPIC_AUTH_TOKEN=
# 不设 ANTHROPIC_MODEL 时，对上述 …/anthropic 或 …/coding 会默认 kimi-k2.5。
# ANTHROPIC_MODEL=kimi-k2.5
# Kimi Code 订阅（部分文档）：ANTHROPIC_BASE_URL=https://api.kimi.com/coding

# --- Kimi（仅当要走 OpenAI 协议 chat/completions 时：设 NOCODE_LLM=moonshot）---
# MOONSHOT_API_KEY=
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
# MOONSHOT_MODEL=kimi-k2.5

# --- Anthropic 官方或其它 Messages API 兼容网关 ---
ANTHROPIC_API_KEY=
# 可选：中转站要求的模型 id（与默认不一致时设置）。
# ANTHROPIC_MODEL=
# Optional override (proxies / VPC / compatible gateway). Default: https://api.anthropic.com
# 不要写末尾的 /v1（SDK 会自行拼接 /v1/messages，多写一层会 404）。
# ANTHROPIC_BASE_URL=

# --- OpenAI (official or OpenAI-compatible: DeepSeek, Groq, local vLLM, etc.) ---
OPENAI_API_KEY=
# Optional. Many stacks read this for custom base URL (LiteLLM, OpenAI SDK compatible mode).
# OPENAI_BASE_URL=

# --- Google Gemini ---
GOOGLE_API_KEY=
# Optional: region-specific or proxy; only if your client supports it.
# GOOGLE_API_BASE=

# --- Mistral ---
# MISTRAL_API_KEY=

# --- Azure OpenAI (use when routing through Azure instead of api.openai.com) ---
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# --- 阿里云通义 DashScope ---
# DASHSCOPE_API_KEY=

# --- 智谱 GLM ---
# ZHIPUAI_API_KEY=

# --- 通用：若你在代码里用单一「当前提供商」开关，可自增变量名并在加载时分支 ---
# LLM_PROVIDER=anthropic
