# Copy to .env and set only what you use. Keep .env out of version control.

# --- Anthropic ---
ANTHROPIC_API_KEY=
# Optional override (proxies / VPC / compatible gateway). Default: https://api.anthropic.com
# ANTHROPIC_BASE_URL=

# --- OpenAI (official or OpenAI-compatible: DeepSeek, Groq, local vLLM, etc.) ---
OPENAI_API_KEY=
# Optional. Many stacks read this for custom base URL (LiteLLM, OpenAI SDK compatible mode).
# OPENAI_BASE_URL=

# --- Google Gemini ---
GOOGLE_API_KEY=
# Optional: region-specific or proxy; only if your client supports it.
# GOOGLE_API_BASE=

# --- Mistral ---
# MISTRAL_API_KEY=

# --- Azure OpenAI (use when routing through Azure instead of api.openai.com) ---
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# --- 阿里云通义 DashScope ---
# DASHSCOPE_API_KEY=

# --- 智谱 GLM ---
# ZHIPUAI_API_KEY=

# --- 月之暗面 Kimi（Moonshot，OpenAI 兼容接口）---
# MOONSHOT_API_KEY=
# Default base: https://api.moonshot.cn/v1 — 与 OpenAI SDK 兼容时设 OPENAI_BASE_URL + 用此 Key 当 OPENAI_API_KEY 也可。
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# --- 通用：若你在代码里用单一「当前提供商」开关，可自增变量名并在加载时分支 ---
# LLM_PROVIDER=anthropic
